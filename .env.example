# === DriverTRACK Production Environment Variables ===
# Copy this to .env and fill in your own secrets.
# DO NOT commit .env to version control.

# Server port
PORT=5000

# PostgreSQL connection string
# For local dev: postgresql://user:password@localhost:5432/drivertrack
# For Render: set this from Render PostgreSQL dashboard
DATABASE_URL=postgresql://user:password@host:5432/drivertrack

# JWT secret: generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_64_char_hex_string

# QR signing secret: generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QR_SECRET=change_me_to_a_different_random_64_char_hex_string
